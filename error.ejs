<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Validation Failed</title>
    <style>
        body { font-family: Arial, sans-serif; background-color: #f8d7da; padding: 20px; }
        .container { background: white; padding: 20px; border-radius: 8px; max-width: 600px; margin: auto; border: 1px solid #f5c6cb;}
        h1 { color: #721c24; }
        li { color: #721c24; margin-bottom: 10px; }
        a { color: #004085; }
    </style>
</head>
<body>
    <div class="container">
        <h1>Server Validation Failed!</h1>
        <p>Please fix the following errors sent from the server:</p>
        <ul>
            <% errors.forEach(function(error) { %>
                <li><%= error %></li>
            <% }); %>
        </ul>
        <br>
        <a href="/">← Back to Form</a>
    </div>
</body>
</html>
